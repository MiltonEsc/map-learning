# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BASE_URL=https://routes.googleapis.com/directions/v2:computeRoutes

# ── OpenWeatherMap ────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── Database ──────────────────────────────────────────────
# SQLite (local, desarrollo):
# DATABASE_URL=sqlite:///./data/traffic_assistant.db

# Supabase / PostgreSQL (producción):
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# ── Application ───────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
TZ=America/Bogota
# CORS: dominio de Vercel (dejar vacío en local para aceptar todo)
ALLOWED_ORIGINS=https://tu-app.vercel.app,http://localhost:3000

# ── Scheduling ────────────────────────────────────────────
TRAFFIC_POLL_INTERVAL_MINUTES=10
WEATHER_POLL_INTERVAL_MINUTES=15
MODEL_RETRAIN_DAY=sunday
MODEL_RETRAIN_HOUR=2

# ── ML Models ─────────────────────────────────────────────
MODELS_DIR=./models_saved
MIN_TRAINING_ROWS=500
PREDICTION_HORIZON_MINUTES=60

# ── Camera ────────────────────────────────────────────────
CAMERA_SOURCE=0
CAMERA_FPS=5
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_MODEL_SIZE=yolov8n

# ── Voice ─────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
TTS_ENGINE=pyttsx3
TTS_VOICE_RATE=175
TTS_VOICE_LANG=es

# ── Alertas ───────────────────────────────────────────────
ALERT_DELAY_THRESHOLD_MINUTES=10
ALERT_ADVANCE_NOTICE_MINUTES=30
